<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Locatic</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">

<nav class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a asp-controller="Home" asp-action="Index" class="text-xl font-bold text-indigo-600 tracking-tight">Locatic</a>
        <div class="flex gap-6 text-sm font-medium text-gray-600">
            <a asp-controller="Brand" asp-action="Index" class="hover:text-indigo-600 transition">Brands</a>
            <a asp-controller="CarModel" asp-action="Index" class="hover:text-indigo-600 transition">Models</a>
            <a asp-controller="Car" asp-action="Index" class="hover:text-indigo-600 transition">Cars</a>
            <a asp-controller="Client" asp-action="Index" class="hover:text-indigo-600 transition">Clients</a>
            <a asp-controller="Reservation" asp-action="Index" class="hover:text-indigo-600 transition">Reservations</a>
        </div>
    </div>
</nav>

<main class="flex-1 max-w-6xl mx-auto w-full px-4 py-8">
    @RenderBody()
</main>

<footer class="text-center text-xs text-gray-400 py-4 border-t border-gray-100">
    Locatic &copy; @DateTime.Now.Year
</footer>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
