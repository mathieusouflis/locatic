@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-16">
    <h1 class="text-4xl font-bold text-indigo-600 mb-4">Welcome to Locatic</h1>
    <p class="text-gray-500 mb-8">Manage your fleet, clients, and reservations.</p>
    <div class="flex justify-center gap-4 flex-wrap">
        <a asp-controller="Car" asp-action="Index" class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition">View Cars</a>
        <a asp-controller="Reservation" asp-action="Index" class="bg-white border border-indigo-600 text-indigo-600 px-5 py-2 rounded-lg hover:bg-indigo-50 transition">View Reservations</a>
    </div>
</div>
