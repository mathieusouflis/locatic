@model IEnumerable<ClientListViewModel>
@{
    ViewData["Title"] = "Clients";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Clients</h1>
    <a asp-action="Create" class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition text-sm">+ Add</a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
            <tr>
                <th class="px-4 py-3 text-left">Name</th>
                <th class="px-4 py-3 text-left">Email</th>
                <th class="px-4 py-3 text-left">Phone</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @foreach (var client in Model)
            {
                <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3 font-medium">@client.FullName</td>
                    <td class="px-4 py-3 text-gray-500">@client.Email</td>
                    <td class="px-4 py-3 text-gray-500">@(client.Phone ?? "–")</td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Any())
    {
        <p class="text-center text-gray-400 py-8">No clients registered.</p>
    }
</div>
