@model ClientCreateViewModel
@{
    ViewData["Title"] = "New Client";
}

<div class="max-w-lg">
    <h1 class="text-2xl font-bold mb-6">New Client</h1>

    <form asp-action="Create" method="post" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label asp-for="FirstName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="FirstName" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                <span asp-validation-for="FirstName" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="LastName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="LastName" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                <span asp-validation-for="LastName" class="text-red-500 text-xs"></span>
            </div>
        </div>

        <div>
            <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <input asp-for="Email" type="email" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
        </div>

        <div>
            <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <input asp-for="Phone" type="tel" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            <span asp-validation-for="Phone" class="text-red-500 text-xs"></span>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition text-sm">Save</button>
            <a asp-action="Index" class="text-gray-500 px-4 py-2 rounded-lg hover:bg-gray-100 transition text-sm">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
