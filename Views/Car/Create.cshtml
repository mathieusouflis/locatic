@model CarCreateViewModel
@{
    ViewData["Title"] = "New Car";
}

<div class="max-w-lg">
    <h1 class="text-2xl font-bold mb-6">New Car</h1>

    <form asp-action="Create" method="post" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
        @Html.AntiForgeryToken()

        <div>
            <label asp-for="LicensePlate" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <input asp-for="LicensePlate" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 font-mono uppercase" />
            <span asp-validation-for="LicensePlate" class="text-red-500 text-xs"></span>
        </div>

        <div>
            <label asp-for="CarModelId" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <select asp-for="CarModelId" asp-items="Model.CarModels" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
                <option value="">-- Select a model --</option>
            </select>
            <span asp-validation-for="CarModelId" class="text-red-500 text-xs"></span>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label asp-for="Year" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Year" type="number" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                <span asp-validation-for="Year" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="DailyRate" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="DailyRate" type="number" step="0.01" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                <span asp-validation-for="DailyRate" class="text-red-500 text-xs"></span>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label asp-for="SeatsCount" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="SeatsCount" type="number" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                <span asp-validation-for="SeatsCount" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="FuelType" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <select asp-for="FuelType" asp-items="Html.GetEnumSelectList<FuelType>()" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400"></select>
                <span asp-validation-for="FuelType" class="text-red-500 text-xs"></span>
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition text-sm">Save</button>
            <a asp-action="Index" class="text-gray-500 px-4 py-2 rounded-lg hover:bg-gray-100 transition text-sm">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
