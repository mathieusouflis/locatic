apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx
  namespace: {{ app_namespace }}
  labels:
    app: nginx
    managed-by: ansible
spec:
  replicas: 1
  selector:
    matchLabels:
      app: nginx
  template:
    metadata:
      labels:
        app: nginx
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "9113"
    spec:
      containers:
        - name: nginx
          image: "{{ nginx_image }}"
          ports:
            - containerPort: 80
          volumeMounts:
            - name: conf
              mountPath: /etc/nginx/conf.d
          readinessProbe:
            # stub_status restreint à 127.0.0.1, kubelet peut pas y accéder direct
            tcpSocket:
              port: 80
          resources:
            requests:
              cpu: 50m
              memory: 32Mi
            limits:
              cpu: 200m
              memory: 64Mi
        - name: nginx-exporter
          image: "{{ nginx_exporter_image }}"
          args:
            - "--nginx.scrape-uri=http://127.0.0.1/stub_status"
          ports:
            - containerPort: 9113
      volumes:
        - name: conf
          configMap:
            name: nginx-conf
